# Server Configuration
PORT=3000
NODE_ENV=development

# WhatsApp Configuration
WHATSAPP_API_TOKEN=your_whatsapp_business_api_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_WEBHOOK_TOKEN=your_webhook_verification_token

# Instagram Configuration
INSTAGRAM_API_TOKEN=your_instagram_graph_api_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id
INSTAGRAM_WEBHOOK_TOKEN=your_instagram_webhook_token

# Facebook Messenger Configuration
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_VERIFY_TOKEN=your_facebook_verify_token

# TiendaNube Configuration
TIENDA_NUBE_ACCESS_TOKEN=your_tiendanube_access_token
TIENDA_NUBE_STORE_ID=your_store_id
TIENDA_NUBE_API_URL=https://api.tiendanube.com

# Stripe Payment
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLIC_KEY=your_stripe_public_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Database
DATABASE_URL=sqlite:./data/ecommerce.db
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
